{{- $is_headless := (env "HEADLESS" | not | not) -}}

data:
  device:
    is_headless: {{ $is_headless }}
  system:
    on_darwin: {{ (eq .chezmoi.os "darwin") }}
    on_debian: {{ and (eq .chezmoi.os "linux" ) (eq .chezmoi.osRelease.id "debian") }}
  user:
    is_root: {{ (eq .chezmoi.username "root") }}
