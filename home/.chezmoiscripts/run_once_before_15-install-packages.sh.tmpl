#!/usr/bin/env bash

{{- if .system.is_darwin }}

if [ -f "/opt/homebrew/bin/brew" ]; then
  # For ARM macOS
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

if ! command -v brew >/dev/null 2>&1; then
  echo "Homebrew is not installed."
  exit 1
fi

brew update

brew bundle --no-lock --file=/dev/stdin <<EOF
# https://github.com/Homebrew/homebrew-bundle

# Formulae
brew "coreutils"
brew "file-formula"
brew "gawk"
brew "git"
brew "gnu-tar"
brew "gnu-sed"
brew "less"
brew "tree"
brew "wget"
brew "zsh"

# Fonts
cask "font-ubuntu-mono-nerd-font"

# System tools
cask "appcleaner"
cask "fliqlo"
cask "maczip"
cask "raycast"
cask "snipaste"
cask "stats"

# Web browser
cask "firefox"
cask "google-chrome"

# Cloud Storage
cask "dropbox"

# Media & Video
cask "iina"
cask "kap"

# Development
cask "orbstack"
cask "visual-studio-code"
cask "wezterm"
EOF

{{- end }}
